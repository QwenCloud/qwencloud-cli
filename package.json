{
  "name": "@qwencloud/qwencloud-cli",
  "version": "1.0.1-alpha.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "QwenCloud CLI - Manage QwenCloud models, usage, and configuration from your terminal",
  "type": "module",
  "bin": {
    "qwencloud": "dist/bin/qwencloud.js"
  },
  "files": [
    "dist/bin/qwencloud.js"
  ],
  "license": "SEE LICENSE IN README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/QwenCloud/qwencloud-cli.git"
  },
  "homepage": "https://github.com/QwenCloud/qwencloud-cli",
  "bugs": {
    "url": "https://github.com/QwenCloud/qwencloud-cli/issues"
  },
  "author": "Qwen Cloud",
  "keywords": [
    "cli",
    "qwencloud",
    "agent"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts --mode prod",
    "build:sourcemap": "tsx scripts/build.ts --mode prod --sourcemap",
    "build:dev": "tsx scripts/build.ts --mode dev",
    "build:analyze": "tsx scripts/build.ts --mode prod --analyze",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"{src,bin,scripts}/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"{src,bin,scripts}/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"{src,bin,scripts}/**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"{src,bin,scripts}/**/*.{ts,tsx,js,json,md}\"",
    "prepare": "tsx scripts/build.ts --mode prod"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "ink": "5.2.1",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "ink-testing-library": "^3.0.0",
    "prettier": "^3.3.3",
    "strip-ansi": "^7.1.0",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "3.2.4"
  }
}
